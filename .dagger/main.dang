type Dang {
  """
  The source directory for the Dang project.
  """
  source: Directory!

  new(ws: Workspace!) {
    self.source = ws.directory("/", gitignore: true)
    self
  }

  """
  Return a compiled Dang binary.
  """
  binary(race: Boolean! = false): File! {
    let args = ["go", "build"]
    if (race) {
      args += ["-race"]
    }
    args += ["-o", "/bin/dang", "./cmd/dang"]

    base.withExec(args).file("/bin/dang")
  }

  """
  Build the Dang binary to ./bin/dang.
  """
  build: Changeset! {
    source.withFile("bin/dang", binary).changes(source)
  }

  """
  Build the documentation site, returning the changeset it produces under
  docs/ (static HTML rendered from lit/, the playground wasm, the syntax
  palette, the search index).

  Mirrors docs/build.sh. The output is gitignored, so this is a check (it
  verifies the build succeeds) rather than a generator — a generator's
  changeset would always look unapplied in CI, where the gitignored artifacts
  are absent.
  """
  docs: Changeset! @check {
    let built = base
      .withWorkdir("/src/docs")
      .withExec(["bash", "./build.sh"])
      .directory("/src/docs")
    source.withDirectory("docs", built).changes(source)
  }

  """
  Runs all code generation procedures, e.g. go generate, tree-sitter generate.
  """
  @generate
  generate: Changeset! {
    generated.directory(".").changes(base.directory("/src"))
  }

  """
  Reformat every Dang source file in place with `dang fmt`, returning the
  changeset.

  Skips the Dagger module sources under mod/, which must keep their explicit
  `pub` keywords until the engine bumps its embedded dang. (The .dagger sources
  are already excluded from `source` via @ignorePatterns.) Files that don't
  parse are skipped too, since tests/errors/ holds deliberately-malformed
  syntax fixtures the formatter can't read.
  """
  @generate
  fmt: Changeset! {
    base
      .withFile("/usr/bin/dang", binary)
      .withExec([
        "bash", "-c",
        """
        find . -name '*.dang' | while read f; do
          dang fmt -lw "$f" || echo "skipping unparseable file: $f" >&2
        done
        """,
      ])
      .directory(".")
      .changes(base.directory("."))
  }

  """
  Run `go mod tidy` for each Go module in the repo.
  """
  tidy: Changeset! {
    base
      .withExec([
        "sh", "-c",
        """
        find . -name go.mod | while read path; do
          go -C $(dirname $path) mod tidy
        done
        """,
      ])
      .directory(".")
      .changes(base.directory("."))
  }

  """
  Build and run a `dang` command.

  Example usage:

    # Run a Dang script
    dang script.dang

    # Run all .dang files in a directory as a module
    dang ./my-module

    # Start interactive REPL
    dang

    # Run with debug logging enabled
    dang --debug script.dang
    dang -d ./my-module
  """
  dang(args: [String!]!): Void {
    base
      .withFile("/usr/bin/dang", binary)
      .withExec(
        ["dang"] + args,
        experimentalPrivilegedNesting: true,
      )
      .sync

    null
  }

  """
  Start a Dang coding agent.
  """
  coder: LLM! {
    dev(source).agent(llm.withEnv(env.withCurrentModule))
  }

  """
  Update the tree-sitter test corpus.
  """
  treesitterUpdate: Changeset! {
    generated
      .withDirectory(
        "./treesitter",
        generated
          .withWorkdir("./treesitter")
          .withExec(["tree-sitter", "test", "--update"])
          .directory("."),
      )
      .directory(".")
      .changes(generated.directory("."))
  }

  """
  Run the linter.
  """
  lint: Void @check {
    base
      .withEnvVariable("GOLANGCI_LINT_CACHE", "/var/cache/golangci-lint")
      .withMountedCache("/var/cache/golangci-lint", cacheVolume("golangci-lint-cache"))
      .withExec(["golangci-lint", "run"])
      .sync

    null
  }

  """
  Bump the pinned Dang version in each editor plugin.
  """
  bumpEditors(repo: GitRepository! @defaultPath(path: "/.git")): Changeset! {
    let commit = repo.head.commit
    base
      .withExec([
        "sed",
        "-i", "editors/zed/extension.toml",
        "-e", "s/commit = \".*\"/commit = \"" + commit + "\"/",
      ])
      .directory(".")
      .changes(base.directory("."))
  }

  """
  Enter a terminal for debugging the Neovim LSP setup.
  """
  nvimDebug: Container! {
    base
      .withFile("/usr/bin/dang", binary)
      .withFile(
        "/root/.config/nvim/init.vim",
        source.file("pkg/lsp/testdata/config.vim"),
      )
      .withWorkdir("./pkg/lsp")
      .terminal(experimentalPrivilegedNesting: true)
  }

  let base: Container! {
    apko
      .wolfi([
        "bash",
        "curl",
        "git",
        "go", "golangci-lint",
        "nodejs", "npm",
        "neovim",
        "clang",
      ])
      .withMountedCache("/go/pkg/mod", cacheVolume("go-mod"))
      # cgo needs a C compiler: the docs build compiles the tree-sitter
      # grammar (danglang) into its highlighter, and Wolfi ships clang, not
      # gcc (Go's default CC).
      .withEnvVariable("CC", "clang")
      .withEnvVariable("GOMODCACHE", "/go/pkg/mod")
      .withMountedCache("/go/build-cache", cacheVolume("go-build"))
      .withEnvVariable("GOCACHE", "/go/build-cache")
      .withExec(["npm", "install", "-g", "tree-sitter-cli@v0.26.8"])
      .withEnvVariable("GOBIN", "/go/bin")
      .withEnvVariable("PATH", "${GOBIN}:${PATH}", expand: true)
      .withDirectory("/src", source)
      .withWorkdir("/src")
      .withExec(["go", "install", "github.com/dagger/otel-go/cmd/otelgotest"])
  }

  """
  Base with ./hack/generate ran.
  """
  generated: Container! {
    base.withExec(["./hack/generate"])
  }

  test: Test! {
    Test(self)
  }
}

type Test {
  let dang: Dang!

  """
  Run go tests.
  """
  @check
  @cache(policy: FunctionCachePolicy.Never)
  go(
    """
    Arguments to pass along to go test.
    """
    args: [String!]! = ["./..."],
  ): Container! {
    dang
      .generated
      # install dang binary for LSP tests
      .withFile("/usr/bin/dang", dang.binary(race: true))
      .withExec(
        ["otelgotest"] + args,
        experimentalPrivilegedNesting: true,
      )
  }

  """
  Run the docs Go module's tests.

  The docs site renderer lives in a separate Go module
  (github.com/vito/dang/docs), so the root `go test ./...` above never reaches
  it. Without this check its linker/literate/highlight tests rot unnoticed.
  """
  @check
  @cache(policy: FunctionCachePolicy.Never)
  docsGo: Container! {
    dang
      .generated
      .withWorkdir("/src/docs")
      .withEnvVariable("CGO_ENABLED", "1")
      .withExec(
        ["otelgotest", "./..."],
        experimentalPrivilegedNesting: true,
      )
  }

  # Intentionally not marked @generate - so it's run intentionally and not
  # redundant with full check runs.
  """
  Update the Golden-style test specimens, treating the current output as
  correct.
  """
  update: Changeset! {
    go(["./tests", "-update"])
      .directory(".")
      .changes(dang.generated.directory("."))
  }

  """
  List available tests.
  """
  list(source: Workspace!): String! {
    let out = "Tests from go test -list . ./...:\n"
    out += go(["-list", ".", "./..."]).stdout
    out += "\n\n"
    out += "Tests from ./tests/test_*:\n"
    source.directory("tests").glob("test_*").each { path =>
      out += "- TestDang/TestLanguage/" + path + "\n"
    }
    out += "\n\n"
    out += "Tests from ./tests/errors/*.dang:\n"
    source.directory("tests/errors").glob("*.dang").each { path =>
      out += "- TestDang/TestErrorMessages/" + path.trimSuffix(".dang") + "\n"
    }
    out
  }

  """
  Run the tree-sitter tests.
  """
  treesitter: Void @check {
    dang
      .generated
      .withWorkdir("./treesitter")
      .withExec(["tree-sitter", "test"])
      .sync

    null
  }
}
