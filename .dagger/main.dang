import Dagger

type Dang {
  """
  The source directory for the Dang project.
  """
  pub source: Dagger.Directory! @Dagger.defaultPath("/") @Dagger.ignorePatterns([
    # TODO: respecting .gitignore would be nice
    "Session.vim"
    "dang"
    "zed-dang/grammars/"
    ".env"
    ".envrc"
    ".dagger"
  ])

  """
  Access the test suites.
  """
  pub test: Test! {
    Test(self)
  }

  """
  Return a compiled Dang binary.
  """
  pub binary(race: Boolean! = false): Dagger.File! {
    let args = ["go", "build"]
    if (race) {
      args += ["-race"]
    }
    args += ["-o", "/bin/dang", "./cmd/dang"]
    base.withExec(args).file("/bin/dang")
  }

  """
  Build the Dang binary to ./bin/dang.
  """
  pub build: Dagger.Changeset! {
    source.withFile("bin/dang", binary).changes(source)
  }

  """
  Runs all code generation procedures, e.g. go generate, tree-sitter generate.
  """
  pub generate: Dagger.Changeset! {
    generated.directory(".").changes(base.directory("/src"))
  }

  """
  Run `go mod tidy` for each Go module in the repo.
  """
  pub tidy: Dagger.Changeset! {
    base.withExec(["sh", "-c", """
      find . -name go.mod | while read path; do
        go -C $(dirname $path) mod tidy
      done
      """]).
      directory(".").
      changes(base.directory("."))
  }

  """
  Build and run a `dang` command.

  Example usage:

    # Run a Dang script
    dang script.dang

    # Run all .dang files in a directory as a module
    dang ./my-module

    # Start interactive REPL
    dang

    # Run with debug logging enabled
    dang --debug script.dang
    dang -d ./my-module
  """
  pub dang(args: [String!]!): Dagger.Void {
    base
      .withFile("/usr/bin/dang", binary)
      .withExec(["dang"] + args, experimentalPrivilegedNesting: true)
      .sync
    null
  }

  """
  Start a Dang coding agent.
  """
  pub coder: Dagger.LLM! {
    Dagger.dev(source).agent(Dagger.llm.withEnv(Dagger.env.withCurrentModule))
  }

  """
  Update the Golden-style test specimens, treating the current output as
  correct.
  """
  pub testUpdate: Dagger.Changeset! {
    generated.
      withExec(["go", "test", "-v", "./tests", "-update"],
        expect: Dagger.ReturnType.ANY,
        experimentalPrivilegedNesting: true).
      directory(".").
      changes(generated.directory("."))
  }

  """
  Update the tree-sitter test corpus.
  """
  pub treesitterUpdate: Dagger.Changeset! {
    generated.
      withDirectory("./treesitter",
        generated.
          withWorkdir("./treesitter").
          withExec(["tree-sitter", "test", "--update"]).
          directory(".")).
      directory(".").
      changes(generated.directory("."))
  }

  """
  Run the linter.
  """
  pub lint: Dagger.Void @Dagger.check {
    base.
      withEnvVariable("GOLANGCI_LINT_CACHE", "/var/cache/golangci-lint").
      withMountedCache("/var/cache/golangci-lint", Dagger.cacheVolume("golangci-lint-cache")).
      withExec(["golangci-lint", "run"]).
      sync
    null
  }

  """
  Bump the pinned Dang version in the Dagger SDK and Zed grammar.
  """
  pub bump(
    repo: Dagger.GitRepository! @Dagger.defaultPath(path: "/.git"),
  ): Dagger.Changeset! {
    let commit = repo.head.commit
    base
      .withExec(["go", "-C", "dagger-sdk", "get", "github.com/vito/dang@"+commit])
      .withExec(["go", "-C", "dagger-sdk", "mod", "tidy"])
      .withExec([
        "sed",
        "-i", "zed-dang/extension.toml",
        "-e", "s/commit = \".*\"/commit = \""+commit+"\"/",
      ])
      .directory(".")
      .changes(base.directory("."))
  }

  """
  Enter a terminal for debugging the Neovim LSP setup.
  """
  pub nvimDebug: Dagger.Container! {
    base.
      withFile("/usr/bin/dang", binary).
      withFile("/root/.config/nvim/init.vim", source.file("pkg/lsp/testdata/config.vim")).
      withWorkdir("./pkg/lsp").
      terminal(experimentalPrivilegedNesting: true)
  }

  let base: Dagger.Container! {
    Dagger.apko.wolfi([
      "bash",
      "git",
      "go", "golangci-lint",
      "nodejs", "npm",
      "neovim",
    ]).
      withMountedCache("/go/pkg/mod", Dagger.cacheVolume("go-mod")).
      withEnvVariable("GOMODCACHE", "/go/pkg/mod").
      withMountedCache("/go/build-cache", Dagger.cacheVolume("go-build")).
      withEnvVariable("GOCACHE", "/go/build-cache").
      withExec(["npm", "install", "-g", "tree-sitter-cli@v0.25.8"]).
      withDirectory("/src", source).
      withWorkdir("/src")
  }

  """
  Base with ./hack/generate ran.
  """
  pub generated: Dagger.Container! {
    base.withExec(["./hack/generate"])
  }
}

type Test {
  pub dang: Dang!

  """
  Run the Dang language tests.
  """
  pub language(
    """
    Only run tests matching this filter.
    """
    filter: String! = "",
    """
    A unique key to force the tests to re-run.
    """
    rerun: String,
  ): Dagger.Void @Dagger.check {
    let args = ["go", "test", "-count=1", "./tests"]
    if (filter != "") {
      args += ["-run", "/"+filter]
    }
    let ctr = dang.generated
    if (rerun != null) {
      ctr = ctr.withEnvVariable("RERUN_KEY", rerun)
    }
    ctr.
      withExec(args, experimentalPrivilegedNesting: true).
      sync
    null
  }

  """
  Run the Dang LSP tests.
  """
  pub lsp(filter: String! = "", verbose: Boolean! = false): Dagger.Void @Dagger.check {
    let args = ["go", "test", "-count=1"]
    if (filter != "") {
      args += ["-run", "LSP/" + filter]
    }
    if (verbose) {
      args += ["-v"]
    }
    args += ["./pkg/lsp/..."]
    dang.generated.
      withFile("/usr/bin/dang", dang.binary(race: true)). # install binary for LSP tests
      withExec(args, experimentalPrivilegedNesting: true).
      sync
    null
  }

  """
  Run the tree-sitter tests.
  """
  pub treesitter: Dagger.Void @Dagger.check {
    dang.generated.
      withWorkdir("./treesitter").
      withExec(["tree-sitter", "test"]).
      sync
    null
  }
}
