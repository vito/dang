<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{.Title.String}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="syntax.css">
<script type="text/javascript" src="js/switcher.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  /* The whole site is colored by the selected base16 scheme (syntax.css
     supplies fallback palettes; css/base16/ + js/switcher.js pick the
     active one). A light scheme makes a light site; the OS light/dark
     preference steers the default scheme choice, an explicit pick wins.
     Slot conventions follow the base16 styling guide: 00-02 background
     depths, 03-05 foreground depths, 08-0E the rainbow. */
  --bg:var(--base00);--bg2:var(--base01);--bg3:var(--base02);
  --fg:var(--base05);--fg2:var(--base04);
  --accent:var(--base09);--accent2:var(--base0A);--on-accent:var(--base00);
  --link:var(--base0D);
  --green:var(--base0B);--cyan:var(--base0C);--pink:var(--base08);--orange:var(--base09);--yellow:var(--base0A);
  --code-bg:var(--base00);--code-border:var(--base02);
  --td-border:var(--base01);
}
html{font-size:16px}
body{background:var(--bg);color:var(--fg);font-family:'Inter',system-ui,sans-serif;line-height:1.6;margin:0;display:flex;min-height:100vh}
code,pre,.mono{font-family:'JetBrains Mono',monospace}
a{color:var(--link);text-decoration:none}
a:hover{text-decoration:underline}
::selection{background:var(--base02)}
/* Auto-links inside code (stdlib references) keep their token color; the
   underline appears on hover so code still reads as code. */
.syntax a{color:inherit;text-decoration:none}
.syntax a:hover{text-decoration:underline}
p code{background:var(--bg3);padding:.15em .4em;border-radius:4px;font-size:.85em}

nav.sidebar{
  position:sticky;top:0;align-self:flex-start;height:100vh;overflow-y:auto;
  width:240px;flex-shrink:0;background:var(--bg2);border-right:1px solid var(--code-border);
  padding:1.5rem 1rem;font-size:.85rem;
}
nav.sidebar h2{font-size:.7rem;text-transform:uppercase;color:var(--fg2);font-weight:600;letter-spacing:.05em;margin:1.25rem 0 .35rem;border:none;padding:0}
nav.sidebar h2:first-child{margin-top:0}
/* part headers are links to the part's stub page, but keep the label look */
nav.sidebar h2 a{display:inline;padding:0;border-radius:0;color:inherit}
nav.sidebar h2 a:hover{background:none;color:var(--fg);text-decoration:none}
nav.sidebar h2 a.current{background:none;color:var(--accent2)}
nav.sidebar ul{list-style:none;padding:0;margin:0}
nav.sidebar li{margin:.15rem 0}
nav.sidebar a{color:var(--fg);display:block;padding:.2rem .4rem;border-radius:4px}
nav.sidebar a:hover{color:var(--fg);background:var(--bg3);text-decoration:none}
nav.sidebar a.current{color:var(--accent2);background:var(--bg3)}
nav.sidebar .brand{font-weight:600;color:var(--fg);font-size:1rem;display:block}
.sidebar-head{margin-bottom:1rem}
/* base16 code-theme switcher (js/switcher.js) */
.sidebar-theme{margin-top:1.5rem;padding-top:1rem;border-top:1px solid var(--code-border)}
.sidebar-theme label{display:block;font-size:.7rem;text-transform:uppercase;color:var(--fg2);font-weight:600;letter-spacing:.05em;margin-bottom:.35rem}
.sidebar-theme select{
  width:100%;padding:.25rem .4rem;font-size:.78rem;font-family:inherit;
  color:var(--fg);background:var(--bg2);border:1px solid var(--code-border);border-radius:4px;
}
.sidebar-theme .reset{display:block;font-size:.72rem;color:var(--fg2);margin-top:.3rem}
.nav-toggle{display:none}
.nav-toggle-btn{display:none}

main{flex:1;max-width:820px;margin:0 auto;padding:2.5rem 2rem 4rem;min-width:0}

/* Hover-revealed deep link on every section heading, sitting in the left
   margin so it doesn't shift the title. Hidden on touch layouts (no hover,
   and the margin is too tight). */
.section-header{position:relative}
.heading-anchor{
  position:absolute;left:-1.1em;top:0;
  color:var(--fg2);font-weight:400;opacity:0;transition:opacity .12s;
}
.section-header:hover .heading-anchor,.heading-anchor:focus{opacity:1}
.heading-anchor:hover{color:var(--link);text-decoration:none}

h1{font-size:1.8rem;font-weight:600;margin-bottom:.25rem}
h2{font-size:1.2rem;font-weight:600;margin:2.5rem 0 .75rem;padding-bottom:.4rem;border-bottom:1px solid var(--code-border)}
h3{font-size:1rem;font-weight:600;margin:1.5rem 0 .5rem}
p{color:var(--fg);font-size:.92rem;margin-bottom:.75rem}
li{color:var(--fg);font-size:.92rem;margin-bottom:.25rem}
ul{padding-left:1.25rem;margin-bottom:.75rem}

/* ── landing-page table of contents (toc.tmpl) ──────────────────────── */
/* Two levels only: chapter rows with the number in its own muted mono
   column, then each chapter's sections as a compact inline run. */
nav.toc{margin:1.5rem 0 2.5rem}
nav.toc h2{font-size:.7rem;text-transform:uppercase;color:var(--fg2);font-weight:600;letter-spacing:.05em;margin:0 0 .75rem;padding:0;border:none}
nav.toc ol{list-style:none;padding:0;margin:0}
nav.toc li{display:grid;grid-template-columns:2rem minmax(0,1fr);column-gap:.75rem;align-items:baseline;margin:0 0 .7rem}
.toc-number{font-family:'JetBrains Mono',monospace;font-size:.78rem;color:var(--fg2);text-align:right}
.toc-chapter{font-size:.92rem;font-weight:500;color:var(--fg)}
.toc-chapter:hover{color:var(--link)}
.toc-sections{font-size:.8rem;line-height:1.7;color:var(--fg2)}
.toc-sections a{color:var(--fg)}
.toc-sections a:hover{color:var(--link)}
/* inline-block keeps the separator outside the hover underline */
.toc-sections a:not(:last-child)::after{content:"·";display:inline-block;color:var(--fg2);margin-left:.35em}
/* Anchor tags under a ToC entry (e.g. the stdlib reference's per-section
   builtins): a wrapping word cloud of compact mono links, no separator since
   many read as `.foo`. */
.toc-anchors{display:flex;flex-wrap:wrap;gap:.15rem .85em;margin-top:.15rem;font-family:'JetBrains Mono',monospace;font-size:.76rem;line-height:1.8}
.toc-anchors a{color:var(--fg2)}
.toc-anchors a:hover{color:var(--link)}

blockquote, .inset{
  border-left:3px solid var(--accent);background:var(--bg2);
  padding:.6rem .9rem !important;margin:.75rem 0 !important;border-radius:0 4px 4px 0;font-size:.85rem;
}
blockquote p, .inset p{color:var(--fg);margin:0}
blockquote p + p, .inset p + p{margin-top:.6rem}
blockquote strong, .inset strong{color:var(--accent2)}

pre{
  background:var(--code-bg);color:var(--base05);border:1px solid var(--code-border);border-radius:6px;
  padding:1rem 1.25rem;font-size:.8rem;line-height:1.65;overflow-x:auto;margin:.75rem 0;
}
pre code{display:block}

/* ── interactive playground ──────────────────────────────────────────── */
.dang-playground{
  background:var(--code-bg);border:1px solid var(--code-border);border-radius:6px;
  margin:1rem 0;overflow:hidden;
}
.dang-playground-btn{
  font-family:'Inter',system-ui,sans-serif;font-size:.74rem;font-weight:500;cursor:pointer;
  border:1px solid var(--code-border);background:var(--bg3);color:var(--fg);
  padding:.22rem .6rem;border-radius:5px;line-height:1.2;transition:background .12s,color .12s,border-color .12s;
}
.dang-playground-btn:hover{color:var(--fg);border-color:var(--fg2)}
.dang-playground-run{background:var(--accent);color:var(--on-accent);border-color:var(--accent)}
.dang-playground-run:hover{background:var(--accent2);border-color:var(--accent2);color:var(--on-accent)}
.dang-playground-run:disabled{opacity:.6;cursor:default}
.dang-playground-github{border-color:var(--fg2)}
/* Overlay editor: a transparent textarea over a highlighted layer. Both
   share identical metrics so the caret lines up with the colored text. The
   code area is colored by the selected base16 scheme. */
.dang-playground-editor{position:relative;background:var(--base00)}
.dang-playground-highlight,
.dang-playground-input{
  margin:0;border:0;box-sizing:border-box;
  font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.65;
  padding:1rem 1.25rem;tab-size:2;
  white-space:pre-wrap;word-break:break-word;overflow-wrap:break-word;
}
.dang-playground-highlight{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
  color:var(--base05);background:transparent;z-index:0;
}
.dang-playground-input{
  position:relative;z-index:1;display:block;width:100%;resize:none;overflow:hidden;
  color:transparent;caret-color:var(--base05);background:transparent;outline:none;
}
.dang-playground-input::selection{background:var(--base02)}
/* token colors (.tok-*) live in syntax.css, shared with the static blocks,
   so the playground and REPL stay in lockstep with the rest of the site. */
.dang-playground-output{
  border-top:1px solid var(--code-border);padding:.7rem 1.25rem;
  font-family:'JetBrains Mono',monospace;font-size:.78rem;line-height:1.6;
  color:var(--fg);white-space:pre-wrap;word-break:break-word;
}
.dang-playground-output.is-empty{display:none}
.dang-playground-stdout{color:var(--fg);margin-bottom:.3rem;white-space:pre-wrap}
.dang-playground-result{color:var(--green);white-space:pre-wrap}
.dang-playground-error{color:var(--pink);white-space:pre-wrap}
.dang-playground-fallback{
  background:var(--code-bg);color:var(--base05);font-family:'JetBrains Mono',monospace;
  font-size:.8rem;line-height:1.65;padding:1rem 1.25rem;margin:0;white-space:pre;overflow-x:auto;
}

/* ── interactive REPL ────────────────────────────────────────────────── */
.dang-repl{
  background:var(--code-bg);border:1px solid var(--code-border);border-radius:6px;
  margin:1rem 0;overflow:hidden;
}
.dang-repl-bar{
  display:flex;align-items:center;gap:.5rem;padding:.45rem .6rem .45rem .9rem;
  background:var(--bg2);border-bottom:1px solid var(--code-border);
}
.dang-repl-label{font-size:.72rem;color:var(--fg2);letter-spacing:.02em}
/* The code area is colored by the selected base16 scheme. */
.dang-repl-body{background:var(--base00)}
.dang-repl-entry{border-bottom:1px solid var(--base01)}
/* prompt + highlighted source, and prompt + input, share these metrics so the
   transcript and the live line align into one column. */
.dang-repl-code,
.dang-repl-inputrow{display:flex;gap:.5rem;align-items:flex-start;padding:.5rem 1.25rem}
.dang-repl-code{padding-bottom:.2rem}
.dang-repl-prompt{
  flex-shrink:0;user-select:none;color:var(--accent);
  font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.65;
}
.dang-repl-codehl{
  flex:1;margin:0;padding:0;border:0;background:transparent;color:var(--base05);
  font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.65;
  white-space:pre-wrap;word-break:break-word;overflow-wrap:break-word;
}
/* Result/output sits flush under the prompt, matching the CLI REPL's "=>". */
.dang-repl-out{
  padding:.1rem 1.25rem .5rem;
  font-family:'JetBrains Mono',monospace;font-size:.78rem;line-height:1.6;
  color:var(--fg);white-space:pre-wrap;word-break:break-word;
}
.dang-repl-out.is-empty{display:none}
/* Live input row: a transparent textarea over a highlighted layer, like the
   playground's editor, but seamless with the transcript above it. */
.dang-repl-editor{position:relative;flex:1}
.dang-repl-highlight,
.dang-repl-input{
  margin:0;border:0;box-sizing:border-box;
  font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.65;
  padding:0;tab-size:2;white-space:pre-wrap;word-break:break-word;overflow-wrap:break-word;
}
.dang-repl-highlight{
  position:absolute;inset:0;pointer-events:none;overflow:hidden;
  color:var(--base05);background:transparent;
}
.dang-repl-input{
  position:relative;z-index:1;display:block;width:100%;resize:none;overflow:hidden;
  color:transparent;caret-color:var(--base05);background:transparent;outline:none;
}
.dang-repl-input::selection{background:var(--base02)}
.dang-repl-input:disabled{cursor:default}
.dang-repl-fallback{
  background:var(--code-bg);color:var(--base05);font-family:'JetBrains Mono',monospace;
  font-size:.8rem;line-height:1.65;padding:1rem 1.25rem;margin:0;white-space:pre;overflow-x:auto;
}

/* ── literate blocks ─────────────────────────────────────────────────── */
/* \dang-literate snippets share one Dang environment per page; their output
   is baked in at build time and replayed client-side on Run (playground.js).
   Editor metrics and output classes are the playground's, so the static and
   live states render identically. */
.dang-literate{
  position:relative;background:var(--code-bg);border:1px solid var(--code-border);
  border-radius:6px;margin:.75rem 0;overflow:hidden;
}
.dang-literate-fallback{
  background:var(--code-bg);color:var(--base05);font-family:'JetBrains Mono',monospace;
  font-size:.8rem;line-height:1.65;padding:1rem 1.25rem;margin:0;white-space:pre;overflow-x:auto;
}
.dang-literate-out{
  border-top:1px solid var(--code-border);padding:.6rem 1.25rem;
  font-family:'JetBrains Mono',monospace;font-size:.78rem;line-height:1.6;
  color:var(--fg);white-space:pre-wrap;word-break:break-word;
}
.dang-literate-out.is-empty{display:none}
/* An edit above this output may have invalidated it; dim until the next Run. */
.dang-literate-out.is-stale{opacity:.45}
/* Run sits in the block's corner, revealed on hover/focus (always shown on
   touch layouts, which have no hover). */
.dang-literate-controls{
  position:absolute;top:.4rem;right:.4rem;display:flex;gap:.3rem;z-index:2;
  opacity:0;transition:opacity .12s;
}
.dang-literate:hover .dang-literate-controls,
.dang-literate:focus-within .dang-literate-controls,
.dang-carousel-slide:hover .dang-literate-controls,
.dang-carousel-slide:focus-within .dang-literate-controls{opacity:1}
@media (hover:none){.dang-literate-controls{opacity:1}}

/* ── feature carousel (carousel.js) ──────────────────────────────────── */
/* A showcase reel. Each slide is a titled \dang-feature — a real \dang-literate
   block, or a live \dang-github-playground. Without JS the slides stack and
   read fine; carousel.js (.is-enhanced) collapses them to one at a time behind
   a single top bar whose tabs slide so the active one is centered and styled
   as the slide's header, the rest trailing off to both sides and fading into
   the prev/next arrows at the edges — a flat carousel. */
.dang-carousel{
  border:1px solid var(--code-border);border-radius:8px;margin:1.5rem 0;
  background:var(--bg2);overflow:hidden;
}
/* The single bar: a horizontally-clipped track of feature tabs. carousel.js
   slides the track so the active tab sits centered as the header. */
.dang-carousel-tabs{
  position:relative;overflow:hidden;
  border-bottom:1px solid var(--code-border);background:var(--bg2);
}
.dang-carousel-track{
  position:relative;display:flex;align-items:baseline;gap:1.1rem;width:max-content;
  padding:.55rem .9rem;
  transition:transform .35s cubic-bezier(.4,0,.2,1);
}
.dang-carousel-tab{
  font-family:'Inter',system-ui,sans-serif;cursor:pointer;white-space:nowrap;
  border:0;background:none;padding:0;line-height:1.3;
  font-size:.8rem;font-weight:500;color:var(--fg2);opacity:.6;
  transition:color .2s,opacity .2s;
}
.dang-carousel-tab:hover{color:var(--fg);opacity:1}
/* Active tab = the slide's header: brighter, bolder, fully opaque. Bold changes
   its width, but carousel.js measures offsets after toggling so the slide still
   aligns. */
.dang-carousel-tab.is-active{color:var(--accent2);font-weight:700;opacity:1;cursor:default}
/* Prev/next arrows at the two edges of the bar, built by carousel.js. Each
   strip's inner edge is a fade (bar bg -> transparent) so the trailing tabs
   dissolve into the arrows on both sides instead of colliding with them.
   pointer-events:none lets the fade zones pass clicks through to the tabs
   beneath, while the buttons re-enable their own. */
.dang-carousel-nav{
  position:absolute;top:0;bottom:0;display:flex;align-items:center;
  pointer-events:none;z-index:1;
}
.dang-carousel-nav-left{
  left:0;justify-content:flex-start;padding:0 2rem 0 .35rem;
  background:linear-gradient(to right, var(--bg2) 1.5rem, transparent);
}
.dang-carousel-nav-right{
  right:0;justify-content:flex-end;padding:0 .35rem 0 2rem;
  background:linear-gradient(to left, var(--bg2) 1.5rem, transparent);
}
.dang-carousel-arrow{
  pointer-events:auto;cursor:pointer;
  font-family:'Inter',system-ui,sans-serif;font-size:1.05rem;line-height:1;
  border:0;background:none;color:var(--fg2);padding:.15rem .3rem;border-radius:4px;
  transition:color .15s;
}
.dang-carousel-arrow:hover{color:var(--accent2)}
/* Enhanced: the active tab is the header, so drop the in-body title; show one
   slide at a time. */
.dang-carousel.is-enhanced .dang-carousel-title{display:none}
.dang-carousel.is-enhanced .dang-carousel-slide{display:none}
.dang-carousel.is-enhanced .dang-carousel-slide.is-active{display:block}
/* Fallback (no JS): stack the slides with dividers and keep the titles. */
.dang-carousel-slide + .dang-carousel-slide{border-top:1px solid var(--code-border)}
.dang-carousel-title{font-size:.82rem;font-weight:600;color:var(--fg);padding:.6rem .9rem .1rem}
/* The embedded code block (literate block or github playground) sits flush;
   position:relative anchors the corner controls overlay (the github playground
   isn't otherwise positioned). */
.dang-carousel-slide .dang-literate,
.dang-carousel-slide .dang-playground{position:relative;margin:0;border:none;border-radius:0;background:var(--code-bg)}
/* Prose tips beneath a slide's code. */
.dang-carousel-notes{
  padding:.7rem .9rem .8rem;border-top:1px solid var(--code-border);background:var(--bg2);
  font-size:.82rem;color:var(--fg2);
}
.dang-carousel-notes p{margin:0 0 .45rem;font-size:.82rem;color:var(--fg2)}
.dang-carousel-notes p:last-child{margin-bottom:0}
.dang-carousel-notes pre{margin:.5rem 0;font-size:.76rem}
.dang-carousel-notes code{font-size:.9em}

table{width:100%;border-collapse:collapse;font-size:.85rem;margin:.75rem 0}
th{text-align:left;padding:.5rem .6rem;color:var(--fg2);font-weight:500;border-bottom:1px solid var(--code-border)}
td{padding:.4rem .6rem;border-bottom:1px solid var(--td-border)}

/* ── stdlib reference ────────────────────────────────────────────────── */
/* A quick-scan index (name → one-liner) precedes long groups; each entry
   below is an anchored card titled by its signature. */
.stdlib-index{width:auto;margin:.5rem 0 2rem}
.stdlib-index td{border-bottom:1px solid var(--td-border);vertical-align:baseline;padding:.25rem .6rem}
.stdlib-index-name{white-space:nowrap;text-align:right;padding-right:1rem}
.stdlib-index-name a{text-decoration:none}
.stdlib-index-name a:hover code{color:var(--accent2)}
.stdlib-index-name code{font-size:.82rem;color:var(--fg)}
.stdlib-index-desc{color:var(--fg)}
.stdlib-entry{margin:1.25rem 0}
/* booklit.Target renders an empty <a id> anchor; give it scroll offset and use
   it to highlight the signature it precedes when linked. */
.stdlib-entry>a[id]{display:block;scroll-margin-top:1.5rem}
/* The signature is syntax-highlighted: its <code> carries the dark code
   background and base color inline, so the bar just adds layout + accent edge. */
.stdlib-sig{display:flex;text-decoration:none;border-left:3px solid var(--accent);border-radius:0 6px 6px 0;overflow:hidden}
.stdlib-sig code{display:block;flex:1;padding:.5rem .8rem;font-size:.82rem;white-space:pre-wrap;word-break:break-word}
/* The receiver/module context (".", "Random.") sits outside the declaration
   proper — only the declaration is parsed for highlighting — but shares the
   code box visually. The syntax class supplies the matching background. */
.stdlib-sig-prefix{padding:.5rem 0 .5rem .8rem;font-size:.82rem;white-space:pre;font-family:'JetBrains Mono',monospace;opacity:.65}
.stdlib-sig-prefix+code{padding-left:0}
.stdlib-sig:hover{border-left-color:var(--accent2)}
/* Right-aligned "@deprecated" badge in a card header. The signature <code> takes
   flex:1, so the badge sits flush against the right edge of the bar. */
.stdlib-deprecated{flex:none;align-self:stretch;display:flex;align-items:center;gap:.3rem;padding:0 0 0 .7rem;font-size:.72rem;font-family:'JetBrains Mono',monospace;white-space:nowrap;color:var(--orange);background:var(--bg2);border-left:1px solid var(--code-border)}
.stdlib-deprecated code{padding-left:0.2rem}
.stdlib-deprecated a{color:var(--accent2);text-decoration:none}
.stdlib-deprecated a:hover{text-decoration:underline}
.stdlib-entry>a[id]:target+.stdlib-sig{border-left-color:var(--accent2);box-shadow:0 0 0 2px var(--accent2)}
.stdlib-desc{color:var(--fg);font-size:.9rem;margin:.4rem 0 0 .85rem}
/* A runnable example: a syntax-highlighted snippet with a Run bar that upgrades
   it into a live, pre-seeded REPL in place (docs/js/playground.js). The snippet
   keeps the syntax class's <code> background, like the signatures above it. */
.stdlib-example{margin:.5rem 0 0 .85rem;border:1px solid var(--code-border);border-radius:6px;overflow:hidden}
.stdlib-example .dang-repl-fallback{background:transparent;border:none;border-radius:0;margin:0;padding:0;white-space:normal;overflow-x:auto}
.stdlib-example .dang-repl-fallback code{display:block;padding:.45rem .7rem;font-size:.8rem;white-space:pre-wrap;word-break:break-word}
.stdlib-example-bar{display:flex;align-items:center;gap:.5rem;padding:.35rem .5rem .35rem .7rem;border-top:1px solid var(--code-border);background:var(--bg2)}
.stdlib-example-label{font-size:.72rem;color:var(--fg2);letter-spacing:.02em}

.links p{margin:0}

.screenshot{margin:.75rem 0}
.screenshot img{width:100%;border-radius:6px;border:1px solid var(--code-border)}

footer{margin-top:4rem;padding-top:1.5rem;border-top:1px solid var(--code-border);font-size:.8rem;color:var(--fg2)}

@media (max-width:760px){
  body{flex-direction:column}
  nav.sidebar{position:sticky;top:0;z-index:10;align-self:stretch;height:auto;width:auto;overflow-y:visible;border-right:none;border-bottom:1px solid var(--code-border);padding:.75rem 1rem}
  .sidebar-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:0}
  .nav-toggle-btn{display:flex;flex-direction:column;gap:5px;cursor:pointer;padding:.4rem;margin:-.4rem}
  .nav-toggle-btn span{display:block;width:22px;height:2px;background:var(--fg);border-radius:2px;transition:transform .2s,opacity .2s}
  .nav-toggle:checked ~ nav.sidebar .nav-toggle-btn span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .nav-toggle:checked ~ nav.sidebar .nav-toggle-btn span:nth-child(2){opacity:0}
  .nav-toggle:checked ~ nav.sidebar .nav-toggle-btn span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  .sidebar-nav{display:none;max-height:70vh;overflow-y:auto;margin-top:.75rem}
  .nav-toggle:checked ~ nav.sidebar .sidebar-nav{display:block}
  main{padding:1.5rem 1rem 3rem}
  .heading-anchor{display:none}
}
</style>
</head>
<body>
{{ $current := . }}
{{ $top := .Top }}
<input type="checkbox" id="nav-toggle" class="nav-toggle">
<nav class="sidebar">
  <div class="sidebar-head">
    <a class="brand" href="{{url $top.PrimaryTag}}">dang</a>
    <label for="nav-toggle" class="nav-toggle-btn" aria-label="Toggle navigation">
      <span></span><span></span><span></span>
    </label>
  </div>
  <div class="sidebar-nav">
    {{ template "sidebar.tmpl" walkContext $current $top }}
    <div class="sidebar-theme" id="choosetheme">
      <label for="styleswitcher">code theme</label>
      <select id="styleswitcher" onchange="switchStyle(event)">
        {{ template "base16-options.tmpl" }}
      </select>
    </div>
  </div>
</nav>
<main>
{{. | render}}
<footer>
  <a href="https://github.com/vito/dang">github.com/vito/dang</a> · Apache-2.0
</footer>
</main>
<script src="js/search.js" defer></script>
<script src="js/feedback.js" defer></script>
<script src="js/playground.js" defer></script>
<script src="js/carousel.js" defer></script>
</body>
</html>
