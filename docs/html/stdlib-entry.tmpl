<div class="stdlib-entry">
  {{- .Partial "Target" | render -}}
  <a class="stdlib-sig" href="{{(.Partial "Reference").Tag | url}}">{{with .Partial "Prefix"}}<span class="stdlib-sig-prefix chroma">{{. | render}}</span>{{end}}{{.Content | render}}</a>
  {{with .Partial "Description"}}<p class="stdlib-desc">{{. | render}}</p>{{end}}
  {{with .Partial "Example"}}{{. | render}}{{end}}
</div>
