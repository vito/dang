# Test String.trimPrefix method

let basic = "/workspace/file.txt".trimPrefix("/workspace")
assert { basic == "/file.txt" }

let no_match = "hello".trimPrefix("goodbye")
assert { no_match == "hello" }

let empty_prefix = "test".trimPrefix("")
assert { empty_prefix == "test" }

let full_string = "prefix".trimPrefix("prefix")
assert { full_string == "" }

let partial_match = "prefixed".trimPrefix("pre")
assert { partial_match == "fixed" }

print("String.trimPrefix() tests passed!")
