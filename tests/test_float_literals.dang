# Test float literal parsing and operations

let pi = 3.14159
let e = 2.71828
let scientific = 1.5e10
let negative_exp = 2.5e-3

assert { pi > 3.0 }
assert { pi < 4.0 }
assert { e > 2.0 }
assert { e < 3.0 }

# Float arithmetic
let float_sum = 1.5 + 2.5
assert { float_sum == 4.0 }

let float_product = 2.5 * 3.0
assert { float_product == 7.5 }

let float_quotient = 7.5 / 2.5
assert { float_quotient == 3.0 }

# Comparisons with floats
assert { 3.14 > 3.0 }
assert { 3.0 < 3.14 }
assert { 2.0 == 2.0 }
assert { 2.5 != 2.0 }

print("Float literal tests passed!")
