import Test

# String literals in case clauses coerce to the operand's scalar type, the
# same way they do at slot/return/arg boundaries. Without coercion, this
# would fail with a String! != URL! mismatch.
pub urlClass = case (homepage) {
  "https://dang-lang.dev" => "official"
  "https://example.com" => "other"
}
assert { urlClass == "official" }

# Same flexibility for enums.
pub statusName = case (status) {
  "ACTIVE" => "act"
  "INACTIVE" => "inact"
}
assert { statusName == "act" }

print("case scalar/enum literal coercion tests passed!")
