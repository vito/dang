# Test object selection syntax for multi-field GraphQL fetching

# Basic object types for testing
type TestUser {
  name: String! = "Anonymous"
  email: String! = "user@example.com"
  age: Int! = 0
  active: Boolean! = true
}

type Profile {
  bio: String! = "No bio"
  avatar: String! = "default.jpg"
}

type TestUserWithProfile {
  name: String! = "Anonymous"
  email: String! = "user@example.com"
  profile: Profile! = Profile("Default bio", "default.jpg")
}

# Test basic object selection
let user = TestUser("Alice", "alice@example.com", 30)
let user_summary = user.{{name, email}}

assert { user_summary.name == "Alice" }
assert { user_summary.email == "alice@example.com" }

# Test object selection with multiple fields
let user_info = user.{{name, email, age, active}}
assert { user_info.name == "Alice" }
assert { user_info.email == "alice@example.com" }
assert { user_info.age == 30 }
assert { user_info.active == true }

# Test nested object selection
let profile = Profile("Software Engineer", "alice.jpg")
let user_with_profile = TestUserWithProfile("Bob", "bob@example.com", profile)
let user_nested = user_with_profile.{{name, profile.{{bio, avatar}}}}

assert { user_nested.name == "Bob" }
assert { user_nested.profile.bio == "Software Engineer" }
assert { user_nested.profile.avatar == "alice.jpg" }

# Test with lists of objects
let users = [
  TestUser("Charlie", "charlie@example.com", 25),
  TestUser("Diana", "diana@example.com", 28),
]

let user_summaries = users.{{name, email}}
assert { user_summaries.length == 2 }
assert { user_summaries[0].name == "Charlie" }
assert { user_summaries[0].email == "charlie@example.com" }
assert { user_summaries[1].name == "Diana" }

# Test with nested lists
let users_with_profile = [
  TestUserWithProfile("Eve", "eve@example.com", Profile("Designer", "eve.jpg")),
  TestUserWithProfile("Frank", "frank@example.com", Profile("Developer", "frank.jpg")),
]

let detailed_summaries = users_with_profile.{{name, profile.{{bio}}}}
assert { detailed_summaries.length == 2 }
assert { detailed_summaries[0].name == "Eve" }
assert { detailed_summaries[0].profile.bio == "Designer" }
assert { detailed_summaries[1].name == "Frank" }
assert { detailed_summaries[1].profile.bio == "Developer" }

print("Object selection tests passed!")
