# Test that objects can reference other objects defined later in the file.
# See: https://github.com/vito/dang/issues/22

type App {
  greet: String! {
    Greeter("world").hello
  }
}

type Greeter {
  let name: String!

  hello: String! {
    "Hello, " + name + "!"
  }
}

assert("forward-referenced object") { App.greet == "Hello, world!" }
assert("direct usage still works") { Greeter("dang").hello == "Hello, dang!" }

print("Object forward reference test passed!")
