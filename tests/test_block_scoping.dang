# Test block scoping behavior for reassignment

# Test 1: Basic outer field reassignment (no local declaration)
let outer_var = 100
{
  assert { outer_var == 100 }
  outer_var = 200
  assert { outer_var == 200 }
}
assert("outer variable should be updated when block doesn't declare local") {
  outer_var == 200
}

# Test 2: Local declaration shadows outer variable (preserves existing behavior)
let shadowed_var = 300
{
  let shadowed_var = 400
  assert { shadowed_var == 400 }
  shadowed_var = 500
  assert { shadowed_var == 500 }
}
assert("outer variable should be unchanged when block declares local") {
  shadowed_var == 300
}

# Test 3: Nested blocks with outer field reassignment
let nested_var = 10
{
  assert { nested_var == 10 }
  nested_var = 20
  assert { nested_var == 20 }

  {
    assert { nested_var == 20 }
    nested_var = 30
    assert { nested_var == 30 }
  }

  assert("inner block should have updated outer variable") { nested_var == 30 }
}
assert("all nested blocks should have updated outer variable") {
  nested_var == 30
}

# Test 4: Mixed shadowing and outer reassignment
let mixed_var = 1
{
  assert { mixed_var == 1 }
  mixed_var = 2
  assert { mixed_var == 2 }

  {
    let mixed_var = 100 # Local declaration shadows outer
    assert { mixed_var == 100 }
    mixed_var = 200
    assert { mixed_var == 200 }
  }

  assert("outer variable should be unchanged by shadowed inner block") {
    mixed_var == 2
  }
}
assert("outer variable should reflect only non-shadowed updates") {
  mixed_var == 2
}

# Test 5: Compound assignment with outer field reassignment
let compound_var = 5
{
  assert { compound_var == 5 }
  compound_var += 10
  assert { compound_var == 15 }
}
assert("compound assignment should update outer variable") {
  compound_var == 15
}

# Test 6: String reassignment
let string_var = "hello"
{
  assert { string_var == "hello" }
  string_var = "world"
  assert { string_var == "world" }
}
assert("string reassignment should update outer variable") {
  string_var == "world"
}

# Test 7: Boolean reassignment
let bool_var = true
{
  assert { bool_var == true }
  bool_var = false
  assert { bool_var == false }
}
assert("boolean reassignment should update outer variable") {
  bool_var == false
}

print("Block scoping tests passed!")
