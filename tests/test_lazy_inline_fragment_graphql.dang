# Test lazy inline fragments on GraphQL values

import Test

# node(id) returns the Node interface - narrow to User with a lazy fragment
pub user_node = node(id: "1").{... on User}
assert { user_node != null }

# The result should be a full lazy User we can chain on
assert { user_node.name == "John Doe" }
assert { user_node.age == 30 }

# Non-null assertion that succeeds
pub user_node_nn: User! = node(id: "1").{... on User!}
assert { user_node_nn.name == "John Doe" }

# Type narrowing that doesn't match returns null
pub not_a_post = node(id: "1").{... on Post}
assert { not_a_post == null }

# Multiple lazy fragments (narrowed union)
pub any_node = node(id: "2").{
  ... on User,
  ... on Post
}
assert { any_node != null }

# nodes() returns [Node!]! - narrow with lazy fragments on a list
pub all_nodes = nodes.{
  ... on User,
  ... on Post
}
assert { all_nodes != null }

print("GraphQL lazy inline fragment tests passed!")
