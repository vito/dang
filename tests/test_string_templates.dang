# Test backtick string templates with ${...} interpolation

# Single-line, no interpolation
let plain = `hello world`
assert { plain == "hello world" }

# Empty
let empty = ``
assert { empty == "" }

# Single-line interpolation
let name = "Ada"
let greeting = `hello ${name}!`
assert { greeting == "hello Ada!" }

# Multiple interpolations
let a = "foo"
let b = "bar"
let multi = `${a}-${b}-${a}`
assert { multi == "foo-bar-foo" }

# \$ is just literal \$
let escaped_dollar = `\$ is dollar`
assert { escaped_dollar == "\\$ is dollar" }

# \${} escapes to literal ${}
let escaped_interp = `\${foo} is not interpolated`
assert { escaped_interp == "${foo} is not interpolated" }

# Lone $ not followed by { is literal
let stray_dollar = `cost $5`
assert { stray_dollar == "cost $5" }

# A backslash is just a backslash — no escape interpretation except for
# \${, which emits a literal ${ opener instead of starting interpolation.
let backslash = `\d+`
assert { backslash == "\\d+" }
let literal_dollar_brace = `prefix \${name} suffix`
assert { literal_dollar_brace == "prefix ${name} suffix" }

# Expression interpolation (not just symbols)
let x = 2
let y = 3
let sum = `${x} + ${y} = ${x + y}`
assert { sum == "2 + 3 = 5" }

# Auto-stringification of non-string values
let n = 42
let b1 = true
let mixed = `n=${n}, b=${b1}`
assert { mixed == "n=42, b=true" }

# null interpolates as the literal string "null" (lenient)
let nullish = `x=${null}`
assert { nullish == "x=null" }

# ---------- Multi-line (triple backtick) ----------

# Basic triple-backtick mirrors triple-quote dedent behavior
let block1 = ```
hello
```
assert { block1 == "hello" }

let block2 = ```
hello
world
```
assert { block2 == "hello\nworld" }

# Indentation: minimum-indent dedent
let block3 = ```
  indented
  body
```
assert { block3 == "indented\nbody" }

# Language tag is parsed but doesn't affect the value
let langged = ```go
func main() {}
```
assert { langged == "func main() {}" }

# Interpolation inside multi-line
let who = "world"
let multi_block = ```
hello ${who}!
```
assert { multi_block == "hello world!" }

# Escaped interpolation opener inside multi-line
let multi_escaped = ```
hello \${who}!
```
assert { multi_escaped == "hello ${who}!" }

# Fence bumping: 4 backticks wrap a 3-backtick code block
let readme = ````
```go
func main() {}
```
````
assert { readme == "```go\nfunc main() {}\n```" }

# 5 backticks wrap 4 backticks
let deeper = `````
````
inner
````
`````
assert { deeper == "````\ninner\n````" }

print("String template tests passed!")
