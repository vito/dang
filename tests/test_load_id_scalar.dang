import Test

# Custom *ID scalar arguments accept either the object handle or a scalar ID.
# This mirrors Dagger core fields like loadDirectoryFromID(id: DirectoryID!).
let john = primaryUser
let jane = secondaryUser

let johnID = "1" :: UserID!
let janeID = "2" :: UserID!

pub loadedFromScalarID: User! = loadUserFromID(id: johnID)
assert { loadedFromScalarID.name == "John Doe" }

pub loadedFromInlineScalarID: User! = loadUserFromID(id: "2" :: UserID!)
assert { loadedFromInlineScalarID.name == "Jane Smith" }

pub loadedFromObject: User! = loadUserFromID(id: john)
assert { loadedFromObject.name == "John Doe" }

pub loadedFromScalarIDs = loadUsersFromIDs(ids: [johnID, janeID]).{name}
assert { loadedFromScalarIDs[0].name == "John Doe" }
assert { loadedFromScalarIDs[1].name == "Jane Smith" }

pub loadedFromObjects = loadUsersFromIDs(ids: [john, jane]).{name}
assert { loadedFromObjects[0].name == "John Doe" }
assert { loadedFromObjects[1].name == "Jane Smith" }

print("load *ID scalar tests passed!")
