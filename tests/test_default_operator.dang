# Test default operator (null coalescing)

# Basic null coalescing
let maybe_null = null
let fallback = "default"
let result = maybe_null ?? fallback

assert { result == "default" }

# Non-null value should not use fallback
let not_null = "value"
let result2 = not_null ?? fallback

assert { result2 == "value" }

# Test with different types
let null_num = null
let fallback_num = 42
let result_num = null_num ?? fallback_num

assert { result_num == 42 }

# Test chaining
let first_null = null
let second_null = null
let final_value = "final"
let chained = first_null ?? (second_null ?? final_value)

assert { chained == "final" }

print("Default operator tests passed!")
