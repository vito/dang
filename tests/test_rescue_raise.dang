# Test raise and error propagation

# raise propagates through function calls
failing: String! {
  raise "kaboom"
}

let result = failing rescue {
  err: Error => "caught: " + err.message
}

assert { result == "caught: kaboom" }

# raise in nested calls
inner: String! {
  raise "inner error"
}

outer: String! {
  inner + " unreachable"
}

let nested = outer rescue {
  err: Error => err.message
}

assert { nested == "inner error" }

# re-raise an error
let rethrow = {
  {
    raise "original"
  } rescue {
    err: Error => raise err
  }
} rescue {
  err: Error => err.message
}

assert { rethrow == "original" }

print("Raise and propagation tests passed!")
