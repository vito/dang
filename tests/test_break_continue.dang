# Test break in .each
pub numbers = [1, 2, 3, 4, 5]
pub sum = 0

numbers.each { num =>
  if (num == 3) {
    break
  }
  sum += num
}

assert { sum == 3 } # Only 1 + 2, stops before 3

# Test continue in .each
pub numbers2 = [1, 2, 3, 4, 5]
pub sum2 = 0

numbers2.each { num =>
  if (num == 3) {
    continue
  }
  sum2 += num
}

assert { sum2 == 12 } # 1 + 2 + 4 + 5, skips 3

# Test break in for loop with condition
pub count = 0
for (count < 10) {
  count += 1
  if (count == 5) {
    break
  }
}

assert { count == 5 }

# Test continue in for loop with condition
pub count2 = 0
pub evens = 0

for (count2 < 10) {
  count2 += 1
  if (count2 % 2 == 1) {
    continue
  }
  evens += 1
}

assert { evens == 5 } # 2, 4, 6, 8, 10

# Test nested .each with break
pub matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
pub found = 0

matrix.each { row =>
  row.each { value =>
    if (value == 5) {
      found = value
      break
    }
  }
  if (found == 5) {
    break
  }
}

assert { found == 5 }

# Test nested .each with continue
# continue should continue the innermost loop
pub result = 0
[1, 2, 3].each { i =>
  [1, 2, 3].each { j =>
    if (i == 2) {
      continue
    }
    if (j == 2) {
      continue
    }
    result += i * j
  }
}

# With i==2, continue skips to next j in the inner loop
# i=1: j=1 -> 1*1=1, j=2 -> continue, j=3 -> 1*3=3
# i=2: j=1 -> continue, j=2 -> continue, j=3 -> continue (all skip due to i==2)
# i=3: j=1 -> 3*1=3, j=2 -> continue, j=3 -> 3*3=9
# Total: 1 + 3 + 3 + 9 = 16
assert { result == 16 }

# Test break with two-variable iteration
pub items = ["a", "b", "c", "d"]
pub lastIndex = 0 - 1

items.each { value, index =>
  if (value == "c") {
    lastIndex = index
    break
  }
}

assert { lastIndex == 2 }

# Test continue with two-variable iteration
pub items2 = ["a", "b", "c", "d"]
pub result3 = ""

items2.each { value, index =>
  if (index == 1) {
    continue
  }
  result3 += value
}

assert { result3 == "acd" } # Skips index 1 (which is "b")
