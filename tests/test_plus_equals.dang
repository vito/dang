# Test += operator

# Integer addition assignment
let x = 5
x += 3
assert { x == 8 }

# String concatenation assignment
let msg = "hello"
msg += " world"
assert { msg == "hello world" }

# List concatenation assignment
let nums = [1, 2]
nums += [3, 4]
assert { nums == [1, 2, 3, 4] }

# Multiple += operations
let counter = 0
counter += 1
counter += 2
counter += 3
assert { counter == 6 }

# Empty list +=
let empty_list = []
empty_list += [1, 2]
assert { empty_list == [1, 2] }

# List += empty list
let some_list = [1, 2]
some_list += []
assert { some_list == [1, 2] }

# String list concatenation assignment
let words = ["hello"]
words += ["world", "test"]
assert { words == ["hello", "world", "test"] }

print("Plus equals tests passed!")
