# Comprehensive test of working Dang language features

# =================== LITERALS ===================
let number = 42
let text = "hello world"
let flag = true
let nothing = null
let numbers_list = [1, 2, 3, 4, 5]
let words_list = ["apple", "banana", "cherry"]

assert { number == 42 }
assert { text == "hello world" }
assert { flag == true }
assert { nothing == null }
assert { numbers_list == [1, 2, 3, 4, 5] }
assert { words_list == ["apple", "banana", "cherry"] }

# =================== CONDITIONALS ===================
let max_num = if (number == 42) { number } else { 100 }
let min_result = if (false) { "false branch" } else { "true branch" }
let no_else_result = if (true) { "has value" }

assert { max_num == 42 }
assert { min_result == "true branch" }
assert { no_else_result == "has value" }

# =================== FUNCTIONS ===================
square(n: Int!): Int! { n }

greet(name: String!): String! { name }

zero_arity_func: String! { "constant_value" }

let squared = square(n: 8)
let greeting = greet(name: "Alice")
let constant = zero_arity_func

assert { squared == 8 }
assert { greeting == "Alice" }
assert { constant == "constant_value" }

# =================== POSITIONAL ARGUMENTS ===================
add_nums(a: Int!, b: Int!): Int! { a }

let mixed_result = add_nums(10, b: 20)
let named_result = add_nums(a: 30, b: 40)

assert { mixed_result == 10 }
assert { named_result == 30 }

# =================== DECLARATIONS WITH TYPES ===================
typed_int: Int! = 999
typed_string: String! = "typed"
let private_value = 123

assert { typed_int == 999 }
assert { typed_string == "typed" }
assert { private_value == 123 }

print("Comprehensive language feature test passed!")
