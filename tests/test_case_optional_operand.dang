# Test case with optional operand
# When no operand is provided, it desugars to case (true)

let x = 5

# Case without operand - conditions in clauses
let result1 = case {
  x < 3 => "less than three"
  x == 5 => "equals five"
  x > 10 => "greater than ten"
}

assert { result1 == "equals five" }

# Another example
let y = 15
let result2 = case {
  y < 10 => "small"
  y < 20 => "medium"
  y >= 20 => "large"
}

assert { result2 == "medium" }

# With just boolean literals
let result3 = case {
  false => "nope"
  true => "yep"
}

assert { result3 == "yep" }

print("Optional case operand tests passed!")
