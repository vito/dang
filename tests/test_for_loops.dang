# Test basic list iteration with .each
pub numbers = [1, 2, 3, 4, 5]
pub sum = 0

numbers.each { num => sum += num }

assert { sum == 15 }

# Test .each with index
pub fruits = ["apple", "banana", "cherry"]
pub result = ""
pub indices = []

fruits.each { fruit, index =>
  result += fruit
  indices += [index]
}

assert { result == "applebananacherry" }
assert { indices == [0, 1, 2] } # 0 + 1 + 2

# Test nested .each
pub matrix = [[1, 2], [3, 4]]
pub total = 0

matrix.each { row =>
  row.each { value =>
    total += value
  }
}

assert { total == 10 }

# Test empty list
pub empty: [Int!]! = []
pub count = 0

empty.each { item => count += 1 }

assert { count == 0 }

# Test single element list
pub single = [42]
pub captured = 0

single.each { item => captured = item }

assert { captured == 42 }
