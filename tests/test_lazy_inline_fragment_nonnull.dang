# Test non-null lazy inline fragment

type Cat {
  name: String!
  lives: Int! = 9
}

type Dog {
  name: String!
  tricks: Int! = 3
}

union Pet = Cat | Dog

cat: Pet! = Cat(name: "Whiskers")

# Non-null type assertion that matches
narrowed: Cat! = cat.{... on Cat!}
assert { narrowed.name == "Whiskers" }
assert { narrowed.lives == 9 }

print("Non-null lazy inline fragment tests passed!")
