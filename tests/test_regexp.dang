# Test Regexp scalar + Match object + String regex methods

# coercion: backtick-template strings auto-coerce to Regexp at call sites
assert { "abc123".containsMatch(`\d+`) }
assert { !"abc".containsMatch(`\d+`) }

# Regexp variable: typed field materializes the scalar
let digits: Regexp! = `\d+`
assert { "x42y".containsMatch(digits) }

# a Regexp is a plain scalar value: equal patterns compare equal, and it
# degrade-compares against its source string
let alsoDigits: Regexp! = `\d+`
assert { digits == alsoDigits }
assert { digits == `\d+` }
assert { digits != `\w+` }

# codec decode into a Regexp slot compile-checks the pattern
let fromJSON = JSON.decode(`"[a-z]+"`) :: Regexp!
assert { "hello".containsMatch(fromJSON) }

# Regexp(...) constructor: builds a pattern from any String expression,
# mirroring Path(...). Compile-checks the pattern, just like materialization.
assert { "x42".containsMatch(Regexp("[0-9]+")) }
assert { Regexp(`\d+`) == `\d+` }
let dyn = "[a-z]+"
assert { "hello".containsMatch(Regexp(dyn)) }
# named-parameter form
assert { "hi".containsMatch(Regexp(pattern: "h.")) }

# match: returns a Match with the whole match and positional captures
let m = "x42y".match(`(\d+)`)
assert { m.string == "42" }
assert { m.captures[0] == "42" }
assert { m.start == 1 }
assert { m.end == 3 }

# no match → null
assert { "abc".match(`\d+`) == null }

# named captures: `named` is a Map keyed by group name
let phone = "555-1212".match(`(?P<area>\d{3})-(?P<num>\d{4})`)
assert { phone.named["area"] == "555" }
assert { phone.named["num"] == "1212" }
assert { phone.named["nope"] == null }

# an unknown name and a named group that did not participate both read as null
let optName = "bar".match(`(?P<pre>foo)?(?P<word>bar)`)
assert { optName.named["pre"] == null }
assert { optName.named["word"] == "bar" }

# positional captures and named captures coexist on the same match
assert { phone.captures[0] == "555" }
assert { phone.captures[1] == "1212" }

# matchAll
let nums = "a1 b22 c333".matchAll(`\d+`)
assert { nums.length == 3 }
assert { nums[0].string == "1" }
assert { nums[2].string == "333" }

# replaceMatches with literal `with`
assert { "hello world".replaceMatches(`\w+`, with: "X") == "X X" }
assert { "hello world".replaceMatches(`\w+`, with: "X", count: 1) == "X world" }

# replaceMatches with backref expansion (Go-style $name)
assert {
  "555-1212".replaceMatches(
    `(?P<area>\d{3})-(?P<num>\d{4})`,
    with: "$area.$num",
  ) == "555.1212"
}
assert { "abc".replaceMatches(`(.)`, with: "[$1]") == "[a][b][c]" }

# rewriteMatches block form: block receives a Match, returns String!
assert {
  "hello world".rewriteMatches(`\w+`) { m =>
    m.string.toUpper
  } == "HELLO WORLD"
}
assert {
  "x1 y22 z333".rewriteMatches(`(\D)(\d+)`) { m =>
    `${m.captures[0]}:${m.captures[1]}`
  } == "x:1 y:22 z:333"
}

# splitMatches
let parts = "a, b ,  c".splitMatches(`\s*,\s*`)
assert { parts.length == 3 }
assert { parts[0] == "a" }
assert { parts[2] == "c" }

# unmatched optional group → ""
let opt = "bar".match(`(foo)?(bar)`)
assert { opt.captures[0] == "" }
assert { opt.captures[1] == "bar" }

print("Regexp tests passed!")
