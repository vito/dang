# Test all String padding methods

# padRight tests
let padright_basic = "hello".padRight(10)
assert { padright_basic == "hello     " }

let padright_already_long = "hello world".padRight(5)
assert { padright_already_long == "hello world" }

let padright_exact = "hello".padRight(5)
assert { padright_exact == "hello" }

let padright_empty = "".padRight(5)
assert { padright_empty == "     " }

# padLeft tests
let padleft_basic = "hello".padLeft(10)
assert { padleft_basic == "     hello" }

let padleft_already_long = "hello world".padLeft(5)
assert { padleft_already_long == "hello world" }

let padleft_exact = "hello".padLeft(5)
assert { padleft_exact == "hello" }

let padleft_empty = "".padLeft(5)
assert { padleft_empty == "     " }

# center tests
let center_basic = "hello".center(11)
assert { center_basic == "   hello   " }

let center_odd_padding = "hello".center(10)
assert { center_odd_padding == "  hello   " }

let center_already_long = "hello world".center(5)
assert { center_already_long == "hello world" }

let center_exact = "hello".center(5)
assert { center_exact == "hello" }

let center_empty = "".center(5)
assert { center_empty == "     " }

print("All String padding tests passed!")
