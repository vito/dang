import Test

# Test explicit scalar casts. String values are not implicitly assignable to
# custom GraphQL scalars; use :: at the value boundary where runtime
# materialization can construct the scalar value.

# =============================================================================
# Test 1: Basic string to custom scalar casts
# =============================================================================

pub urlResult = fetchURL(url: "https://example.com" :: URL!)
assert { urlResult == "Fetched: https://example.com" }

pub tsResult = formatTimestamp(ts: "2024-01-15T10:30:00Z" :: Timestamp!)
assert { tsResult == "Formatted: 2024-01-15T10:30:00Z" }

pub jsonResult = parseJSON(data: "{\"key\": \"value\"}" :: JSON!)
assert { jsonResult == "Parsed JSON: {\"key\": \"value\"}" }

pub bigIntResult = addBigInt(
  a: "12345678901234567890" :: BigInt!,
  b: "98765432109876543210" :: BigInt!
)
assert { bigIntResult == "12345678901234567890+98765432109876543210" }

# =============================================================================
# Test 2: Nullable scalar parameters
# =============================================================================

pub nullableWithValue = fetchURLNullable(url: "https://nullable.com" :: URL!)
assert { nullableWithValue == "Fetched nullable: https://nullable.com" }

# Nullable URL with null - omitting the argument
pub nullableWithNull = fetchURLNullable
assert { nullableWithNull == null }

# =============================================================================
# Test 3: List of scalars
# =============================================================================

pub multiResult = fetchMultipleURLs(
  urls: ["https://a.com", "https://b.com", "https://c.com"] :: [URL!]!
)
assert { multiResult[0] == "Fetched[0]: https://a.com" }
assert { multiResult[1] == "Fetched[1]: https://b.com" }
assert { multiResult[2] == "Fetched[2]: https://c.com" }

# =============================================================================
# Test 4: Scalar values from GraphQL can still be used directly
# =============================================================================

pub urlValue = homepage
assert { urlValue == "https://dang-lang.dev" }

pub fetchedHomepage = fetchURL(url: urlValue)
assert { fetchedHomepage == "Fetched: https://dang-lang.dev" }

# =============================================================================
# Test 5: Variables and expressions can be explicitly cast
# =============================================================================

pub myUrl = "https://variable.com"
pub varResult = fetchURL(url: myUrl :: URL!)
assert { varResult == "Fetched: https://variable.com" }

pub base = "https://"
pub domain = "concat.com"
pub concatResult = fetchURL(url: (base + domain) :: URL!)
assert { concatResult == "Fetched: https://concat.com" }

# =============================================================================
# Test 6: Mixed scalar and non-scalar arguments
# =============================================================================

pub greeting = hello(name: "World")
assert { greeting == "Hello, World!" }

print("All explicit scalar cast tests passed!")
