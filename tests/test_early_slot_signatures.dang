# Variables with explicit or statically-known types are declared before type
# bodies are checked, even when their values are evaluated later.

pub computedDefault: String! = "A" + "da"

type ComputedDefaultUser {
  pub name: String! = computedDefault
}

assert { ComputedDefaultUser.name == "Ada" }

pub literalTemplateDefault = `Ada`

type LiteralTemplateDefaultUser {
  pub name: String! = literalTemplateDefault
}

assert { LiteralTemplateDefaultUser.name == "Ada" }

pub who = "Grace"
pub templatedDefault = `hello #{who}`

type TemplateDefaultUser {
  pub message: String! = templatedDefault
}

assert { TemplateDefaultUser.message == "hello Grace" }

# A variable can construct a hoisted type before a later computed default's
# value has been evaluated. The constructor must wait for the default's
# dependency even though it is hidden inside the type body.
pub runtimeUser = RuntimeTemplateDefaultUser

pub runtimeWho = "Katherine"
pub runtimeTemplatedDefault = `hello #{runtimeWho}`

type RuntimeTemplateDefaultUser {
  pub message: String! = runtimeTemplatedDefault
}

assert { runtimeUser.message == "hello Katherine" }

# Forward reads hidden behind function calls are handled by lazy module slots.
pub lazyFunctionValue = lazyFunction
pub lazyFunctionLater = "ok"
pub lazyFunction: String! { lazyFunctionLater }

assert { lazyFunctionValue == "ok" }

pub lazyExplicitCallValue = lazyExplicitCallFunction("called")
pub lazyExplicitCallLater = "ok"
pub lazyExplicitCallFunction(prefix: String!): String! { prefix + lazyExplicitCallLater }

assert { lazyExplicitCallValue == "calledok" }

# Local bindings inside functions should not create false top-level cycles.
pub lazyLocalValue = lazyLocalFunction
pub lazyLocalLater = lazyLocalValue
pub lazyLocalFunction: String! {
  let lazyLocalLater = "x"
  lazyLocalLater
}

assert { lazyLocalValue == "x" }
assert { lazyLocalLater == "x" }
