# Test source-level inline union types in annotations and type hints.

type Cat {
  pub name: String!
  pub lives: Int! = 9
}

type Dog {
  pub name: String!
  pub tricks: Int! = 3
}

pub describePet(pet: Cat | Dog): String! {
  case (pet) {
    c: Cat => c.name + " has " + toString(c.lives) + " lives"
    d: Dog => d.name + " knows " + toString(d.tricks) + " tricks"
  }
}

pub describeNonNullPet(pet: (Cat | Dog)!): String! {
  describePet(pet)
}

let cat = Cat(name: "Whiskers")
let dog = Dog(name: "Rex", tricks: 5)

assert { describePet(cat) == "Whiskers has 9 lives" }
assert { describePet(dog) == "Rex knows 5 tricks" }
assert { describeNonNullPet(cat) == "Whiskers has 9 lives" }

pub inlinePet: Cat | Dog = cat
assert { describePet(inlinePet) == "Whiskers has 9 lives" }

pub hintedPet = dog :: Cat | Dog
assert { describePet(hintedPet) == "Rex knows 5 tricks" }

pub stringify(value: String | Int): String! {
  case (value) {
    s: String => s
    i: Int => toString(i)
  }
}

assert { stringify("hello") == "hello" }
assert { stringify(42) == "42" }

pub describeMixed(value: Cat | String): String! {
  case (value) {
    c: Cat => c.name
    s: String => s
  }
}

assert { describeMixed(cat) == "Whiskers" }
assert { describeMixed("plain string") == "plain string" }

print("inline union type tests passed!")
