# Generic argument inference should not depend on argument order.

chooseFirst(x: a, y: a): a { x }

chooseSecond(x: a, y: a): a { y }

pub nullThenInt = chooseFirst(null, 1)
pub intThenNull = chooseFirst(1, null)
pub secondNullThenInt = chooseSecond(null, 1)
pub secondIntThenNull = chooseSecond(1, null)

assert { nullThenInt == null }
assert { intThenNull == 1 }
assert { secondNullThenInt == 1 }
assert { secondIntThenNull == null }

# The inferred result type is nullable regardless of which argument supplied null.
acceptNullable(value: Int): Int { value }

assert { acceptNullable(nullThenInt) == null }
assert { acceptNullable(intThenNull) == 1 }

print("Generic argument inference tests passed!")
