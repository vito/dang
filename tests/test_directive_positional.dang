# Test positional arguments in directive applications

# Declare directives with arguments
directive @deprecated(reason: String!) on FIELD_DEFINITION

directive @cache(ttl: Int!, key: String) on FIELD_DEFINITION

type User {
  # Test positional argument (single arg)
  oldField: String! @deprecated("This field is obsolete")

  # Test mixed positional and named arguments
  cachedField: String! @cache(300, key: "user_cache")

  # Test all positional arguments
  anotherCachedField: String! @cache(60, "another_cache")
}

print("Directive positional arguments test passed!")
