# Test advanced block arg cases

# Multiple parameter block arg
pairs: [[Int!]!]! = [[1, 2], [3, 4], [5, 6]]
# Note: pair[0] returns Int (nullable) because indexing can fail,
# so the map returns [Int]! not [Int!]!
sums: [Int]! = pairs.map { pair => pair[0] + pair[1] }
assert { sums[0] == 3 }
assert { sums[1] == 7 }
assert { sums[2] == 11 }

# Chaining with block args
numbers: [Int!]! = [1, 2, 3, 4, 5, 6]
result: [Int!]! = numbers
  .filter { x => x % 2 == 0 }
  .map { x => x * 3 }
assert { result[0] == 6 }
assert { result[1] == 12 }
assert { result[2] == 18 }

# Block arg with empty list
empty: [Int!]! = []
mapped: [Int!]! = empty.map { x => x * 2 }
assert { mapped == [] }

# TODO: Nested block calls currently don't work due to type variable scoping issues
nested: [[Int!]!]! = [[1, 2], [3, 4]]
doubled_nested: [[Int!]!]! = nested.map { inner =>
  inner.map { x => x * 2 }
}

print("Block arg advanced tests passed!")
