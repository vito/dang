# Test `.{ }` dot-block application: call a block with the receiver as its arg.

double(x: Int!): Int! { x * 2 }

add(a: Int!, b: Int!): Int! { a + b }

# Implicit `_`: foo.{ bar(_) } == bar(foo)
assert { 21.{ double(_) } == 42 }

# Explicit param: foo.{ x => bar(x) } == bar(foo)
assert { 21.{ x => double(x) } == 42 }

# The block body is just an expression; the receiver flows in as `_`
assert { 5.{ _ + 1 } == 6 }
assert { 5.{ _ * _ } == 25 }

# Interleaves with real method calls in one chain
type Box {
  n: Int! = 0

  incr: Box! {
    n += 1
    self
  }
}

let result = Box(10).{ x => Box(x.n + 5) }.incr.{ b => b.n }
assert { result == 16 }

# Chained dot-blocks
assert { 3.{ _ + 1 }.{ _ * 10 } == 40 }

# A 0-param block ignores the receiver and returns its body
assert { 99.{ 7 } == 7 }

# Two uses of the receiver via explicit binding
assert { 4.{ x => add(x, x) } == 8 }

# Null receiver is bound (not short-circuited): the block decides
maybe: Int = null
assert { maybe.{ _ == null } == true }
assert { maybe.{ x => if (x == null) { -1 } else { x } } == -1 }

# Adjacency: `.{` followed by a `{{ }}` record literal parses as a dot-block
# whose body is a record, not as a selection.
let rec = 5.{ {{doubled: _ * 2}} }
assert { rec.doubled == 10 }

print("Dot-block tests passed!")
