# Test basic rescue expressions

# rescue a raised error
let caught = {
  raise "oops"
} rescue {
  err: Error => "caught: " + err.message
}

assert { caught == "caught: oops" }

# success path passes through
let ok = "hello" rescue {
  err: Error => "unreachable"
}

assert { ok == "hello" }

# rescue with no error returns the operand value
let number = 42 rescue {
  err: Error => 0
}

assert { number == 42 }

print("Basic rescue tests passed!")
