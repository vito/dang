# Test edge cases for object constructors

# Object with no constructor parameters (only functions)
type FunctionOnly {
  getValue: Int! {
    42
  }

  getString: String! {
    "hello"
  }
}

assert { FunctionOnly.getValue == 42 }
assert { FunctionOnly.getString == "hello" }

# Constructor with default values that depend on external variables
let globalValue = "global"

type UsingGlobals {
  local: String! = globalValue + "_local"
}

assert { UsingGlobals.local == "global_local" }

# Object with nested object default values
type NestedDefaults {
  pub person = {{
    name: "John",
    details: {{
      age: 30,
      active: true
    }}
  }}
}

assert { NestedDefaults.person.name == "John" }
assert { NestedDefaults.person.details.age == 30 }
assert { NestedDefaults.person.details.active == true }

# Constructor with list default values
type ListDefaults {
  numbers: [Int!]! = [1, 2, 3]
  names: [String!]! = ["a", "b"]
}

assert { ListDefaults.numbers == [1, 2, 3] }
assert { ListDefaults.names == ["a", "b"] }

# Object with constructor parameters that have complex types
type ComplexTypes {
  pub config = {{
    items: ["default"],
    count: 1
  }}
  pub metadata = {{
    version: "1.0",
    tags: ["test"]
  }}
}

print(JSON.encode(ComplexTypes.metadata))
assert { ComplexTypes.config.items == ["default"] }
assert { ComplexTypes.config.count == 1 }
assert { ComplexTypes.metadata.version == "1.0" }
assert { ComplexTypes.metadata.tags == ["test"] }

print("Constructor edge case tests passed!")
