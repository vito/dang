# Test list.filter() method

# Basic functionality - filter even numbers
numbers: [Int!]! = [1, 2, 3, 4, 5]
evens: [Int!]! = numbers.filter { x => x % 2 == 0 }
assert { evens[0] == 2 }
assert { evens[1] == 4 }

# Filter strings that start with 'h'
words: [String!]! = ["hello", "world", "hi", "there"]
h_words: [String!]! = words.filter { w => w.hasPrefix("h") }
assert { h_words[0] == "hello" }
assert { h_words[1] == "hi" }

# Filter all elements (none match)
all_filtered: [Int!]! = [1, 2, 3].filter { x => false }
assert { all_filtered == [] }

# Filter no elements (all match)
none_filtered: [Int!]! = [1, 2, 3].filter { x => true }
assert { none_filtered == [1, 2, 3] }

# Empty list
empty: [Int!]! = []
filtered_empty: [Int!]! = empty.filter { x => x > 0 }
assert { filtered_empty == [] }

print("List filter tests passed!")
