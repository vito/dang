# Test the implicit `_` block parameter (Kotlin `it`-style)

# `_` in map/filter/each
doubled: [Int!]! = [1, 2, 3].map { _ * 2 }
assert { doubled[0] == 2 }
assert { doubled[1] == 4 }
assert { doubled[2] == 6 }

evens: [Int!]! = [1, 2, 3, 4].filter { _ % 2 == 0 }
assert { evens == [2, 4] }

total: Int! = 0
[1, 2, 3].each { total += _ }
assert { total == 6 }

# Every `_` refers to the same single argument (not Scala positional params)
squares: [Int!]! = [2, 3, 4].map { _ * _ }
assert { squares == [4, 9, 16] }

# Explicit-param block ignores `_` magic: `_x` is an ordinary identifier
named: [Int!]! = [1, 2, 3].map { _x => _x + 10 }
assert { named == [11, 12, 13] }

# Nested blocks shadow: inner `_` is the inner element
nested: [[Int!]!]! = [[1, 2], [3, 4]].map { _.map { _ + 100 } }
assert { nested[0] == [101, 102] }
assert { nested[1] == [103, 104] }

# A nested block with explicit params: `_` inside refers to the outer block
outer: [[Int!]!]! = [10, 20].map { [1, 2].map { x => x + _ } }
assert { outer[0] == [11, 12] }
assert { outer[1] == [21, 22] }

print("Implicit underscore tests passed!")
