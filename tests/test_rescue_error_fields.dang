# Test error message access

# error message from a string raise
let result = {
  raise "not found"
} rescue {
  err: Error => err.message
}

assert { result == "not found" }

# error message from a runtime error
let divResult = {
  let x = 1 / 0
  "ok"
} rescue {
  err: Error => err.message
}

assert { divResult == "division by zero" }

print("Error field tests passed!")
