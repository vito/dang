let maxResponseLength = 30000
let workspacePath = "/workspace"

"""
A Dagger-native sandboxed coding agent.
"""
type Doug {
  """
  A CLI friendly entrypoint for starting a coding agent developing in a workdir.
  """
  pub dev(
    source: Workspace!,
    module: Module,
    branch: String! = "",
  ): LLM! {
    let agentEnv = env
    if (module != null) {
      agentEnv = agentEnv.withMainModule(module)
    }
    if (branch != "") {
      source = source.withBranch(branch)
    }
    agentEnv = agentEnv.withWorkspace(source)
    agent(llm.withEnv(agentEnv))
  }

  """
  Returns a Doug coding agent
  """
  pub agent(base: LLM!): LLM! {
    base
      .withEnv(
        base
          .env
          .withCurrentModule
          .withStringInput("TODOs", "", "Your TODO list"),
      )
      .withSystemPrompt(
        {
          let promptsDir = currentModule.source.directory("prompts/system/")
          let providerFile = base.provider + ".txt"
          if (promptsDir.entries.contains(providerFile)) {
            promptsDir.file(providerFile).contents
          } else {
            promptsDir.file("doug.txt").contents
          }
        },
      )
      .withSystemPrompt(reminderPrompt(llm.env.workspace))
      .withSystemPrompt(skillsPrompt(llm.env.workspace))
  }

  """
  Read the contents of a file. Output is truncated to 2000 lines by default. Each line is prefixed with its line number. Use offset/limit for large files. When you need the full file, continue with offset until complete.
  """
  pub readFile(
    source: Workspace!,
    """
    Relative path within the workspace
    """
    filePath: String!,
    """
    Line offset to start reading from
    """
    offset: Int! = 0,
    """
    Limit the number of lines read
    """
    limit: Int! = 2000,
  ): String! {
    let fileContents = source
      .file(normalize(filePath))
      .contents(
        offsetLines: offset,
        limitLines: limit,
      )

    if (fileContents == "") {
      "WARNING: File contents are empty."
    } else {
      # fileContents
      #	 .split("\n", 0)
      #	 .map { (i, x) => toJSON(offset+i+1).padLeft(6) + "→" + line + "\n" } # TODO: template
      #	 .join("\n")
      let numbered = ""
      fileContents.split("\n", 0).each { line, i =>
        # TODO: template
        numbered += toJSON(offset + i + 1).padLeft(6) + "→" + line + "\n"
      }

      numbered.trimSuffix("\n")
    }
  }

  """
  Edit a file by replacing exact text. The oldString must match exactly (including whitespace). Use this for precise, surgical edits. For larger edits, use the Write tool to overwrite files.
  """
  pub editFile(
    source: Workspace!,
    """
    Relative path within the workspace
    """
    filePath: String!,
    """
    Unique search string to replace within the file, or non-unique if replaceAll is true
    """
    oldString: String!,
    """
    New text content
    """
    newString: String!,
    """
    Replace all occurrences
    """
    replaceAll: Boolean! = false,
  ): Changeset! {
    let normalizedPath = normalize(filePath)
    let base = source.directory(".", include: [normalizedPath])
    let changes = base
      .withFile(
        normalizedPath,
        source
          .file(normalizedPath)
          .withReplaced(oldString, newString, all: replaceAll),
      )
      .changes(base)
    source.stage(changes)
    changes
  }

  """
  Remove a file or directory.
  """
  pub rm(
    source: Workspace!,
    """
    Relative path within the workspace
    """
    path: String!,
  ): Changeset! {
    let normalizedPath = normalize(path)
    let base = source
      .directory(".", include: [normalizedPath])
    let changes = base.withoutFile(path).changes(base)
    source.stage(changes)
    changes
  }

  """
  Rename or move a file or directory. Parent directories are created automatically.
  """
  pub mv(
    source: Workspace!,
    """
    Relative path within the workspace of the file or directory to move
    """
    oldPath: String!,
    """
    Destination path within the workspace
    """
    newPath: String!,
  ): Changeset {
    let normalizedPath = normalize(oldPath)
    let base = source
      .directory(".", include: [normalizedPath])
    let changes = if (base.exists(oldPath, expectedType: ExistsType.REGULAR_TYPE)) {
      base
        .withFile(newPath, source.file(oldPath))
        .withoutFile(oldPath)
        .changes(base)
    } else if (base.exists(oldPath, expectedType: ExistsType.DIRECTORY_TYPE)) {
      base
        .withDirectory(newPath, source.directory(oldPath))
        .withoutDirectory(oldPath)
        .changes(base)
    }
    source.stage(changes)
    changes
  }

  """
  Commit staged changes. All prior EditFile, Write, Rm, and Mv changes are included. Returns the commit hash.
  """
  pub commit(
    source: Workspace!,
    """
    The commit message
    """
    message: String!,
  ): String! {
    source.commit(message)
  }

  """
  Write content to a file. Creates the file if it doesn't exist, overwrites if it does. Automatically creates parent directories.
  """
  pub write(
    source: Workspace!,
    """
    Relative path within the workspace
    """
    filePath: String!,
    """
    Complete file content to write
    """
    contents: String!,
  ): Changeset! {
    let normalizedPath = normalize(filePath)
    let base = source.directory(".", include: [normalizedPath])
    let changes = base.withNewFile(normalize(filePath), contents).changes(base)
    source.stage(changes)
    changes
  }

  """
  Find files by glob pattern. Hidden files are skipped. Use '**' to match across directories.
  """
  pub glob(
    source: Workspace!,
    """
    Relative glob pattern to find within the workspace
    """
    pattern: String!,
  ): Void {
    let matches = source.glob(pattern)
    let anyMatched = false
    matches.each { path =>
      if (path.hasPrefix(".") or path.contains("/.")) {
        # Filter out hidden files
        continue
      }
      anyMatched = true
      print(path)
    }
    if (!anyMatched) {
      print("No files found.")
    }
  }

  """
  Search file contents for a regex pattern. Respects .gitignore. Use literalText for exact matches. Use glob to filter by file type.
  """
  pub grep(
    source: Workspace!,
    """
    Regular expression pattern to grep for
    """
    pattern: String!,
    """
    Treat pattern as literal text instead of a regular expression
    """
    literalText: Boolean! = false,
    """
    Relative paths within the workspace to limit the search
    """
    paths: [String!]! = [],
    """
    Relative path globs within the workspace to limit the search
    """
    glob: [String!]! = [],
    """
    Allow the pattern to span multiple lines
    """
    multiline: Boolean! = false,
    """
    Show the matching content
    """
    content: Boolean! = false,
    """
    Case-insensitive search
    """
    insensitive: Boolean! = false,
    """
    Limit the number of matches
    """
    limit: Int! = 1000,
  ): String! {
    let normalizedPaths = paths.map { p => normalize(p) }

    let matches = source
      .search(
        pattern: pattern,
        literal: literalText,
        paths: normalizedPaths,
        globs: glob,
        multiline: multiline,
        dotall: multiline,
        filesOnly: !content,
        insensitive: insensitive,
        limit: limit,
        skipIgnored: true,
      )

    toJSON(matches.{id}.length) + " matches found"
  }

  """
  Launch a read-only sub-agent for research. Runs in a sandboxed fork; all filesystem changes are discarded. Launch multiple concurrently when possible. The agent returns a single message report.
  """
  pub research(
    source: Workspace!,
    """
    A brief description of the task to show to the user
    """
    description: String!,
    """
    The prompt for the sub-agent
    """
    prompt: String!,
  ): String! {
    llm
      .withEnv(currentEnv.withoutOutputs) # TODO: this isn't actually read-only... do we need it to be?
      .withBlockedFunction("Doug", "research")
      .withBlockedFunction("Doug", "rabbithole")
      .withoutDefaultSystemPrompt
      .withSystemPrompt("""
      Given the user's message, use the tools available to complete the task. Do what has been asked; nothing more, nothing less. When you complete the task simply respond with a detailed writeup.

      Notes:
      - You are running in a sandboxed copy of the original filesystem; your writes will be discarded, so feel free to use it as a scratch space if needed.
      - You are in an isolated sandboxed environment. Any writes you perform will be discarded. If the task implies they should be kept, fail early.
      - Your final response should always share relevant file names and code snippets. Paths should always be relative to the project root.
      - You MUST avoid using emojis.
      """)
      .withSystemPrompt(reminderPrompt(workspace: source))
      .withPrompt(prompt)
      .loop
      .lastReply
  }

  """
  Launch a read-write sub-agent for a focused task. Runs in series. Use to reduce context usage when the goal and scope are clear.
  """
  pub rabbithole(
    source: Workspace!,
    """
    A brief description of the task to show to the user
    """
    description: String!,
    """
    The prompt for the sub-agent
    """
    prompt: String!,
  ): Void {
    let reminderPromptText = reminderPrompt(workspace: source)

    let result = llm
      .withEnv(currentEnv.withoutOutputs)
      .withBlockedFunction("Doug", "research")
      .withBlockedFunction("Doug", "rabbithole")
      .withoutDefaultSystemPrompt
      .withSystemPrompt("""
      Given the user's message, use the tools available to complete the task. Do what has been asked; nothing more, nothing less. When you complete the task simply respond with a detailed writeup.

      Notes:
      - Don't worry about saying which files you updated; that'll happen automatically.
      - Put a tl;dr at the bottom so the caller can decide whether it needs to
      read the rest of the report.
      - You MUST avoid using emojis.
      """)
      .withSystemPrompt(reminderPromptText)
      .withPrompt(prompt)
      .loop

    # show the reply, which will be tl;dred
    print(result.lastReply)

    null
  }

  """
  Track TODOs. Call with items in pending/inProgress/completed to update. Call with no arguments to print the current list. Use for tasks with 3+ steps.
  """
  pub todoWrite(
    pending: [String!]! = [],
    inProgress: [String!]! = [],
    completed: [String!]! = [],
  ): Env! {
    # Try to get current TODOs, default to empty string if not found
    # Since we don't have try/catch, we'll assume it returns empty string on failure
    let currentTodos = currentEnv.input("TODOs").asString

    let existingCompleted = [] :: [String!]!
    let existingInProgress = [] :: [String!]!
    let existingPending = [] :: [String!]!

    # Parse current TODOs from "state:description" format
    let currentTodoLines = currentTodos.split("\n")

    # Build list of all descriptions being updated
    let updatingDescriptions = pending + inProgress + completed

    currentTodoLines.each { todo =>
      if (todo != "") {
        # Split on first colon only (limit=2) to handle descriptions with colons
        let parts = todo.split(":", limit: 2)
        let state = parts[0] ?? "pending"
        let description = parts[1] ?? todo

        # Only keep existing TODOs that aren't being updated
        if (!updatingDescriptions.contains(description)) {
          if (state == "completed") {
            existingCompleted += [description]
          } else if (state == "in_progress") {
            existingInProgress += [description]
          } else {
            existingPending = existingPending + [description]
          }
        }
      }
    }

    let formattedTodos = ""
    let encodedTodos = ""

    (existingCompleted + completed).each { todo =>
      encodedTodos += "completed:" + todo + "\n"
      formattedTodos += "■ \x1b[32m\x1b[9m" + todo + "\x1b[0m\n"
    }
    (existingInProgress + inProgress).each { todo =>
      encodedTodos += "in_progress:" + todo + "\n"
      formattedTodos += "□ \x1b[33m" + todo + "\x1b[0m\n"
    }
    (existingPending + pending).each { todo =>
      encodedTodos += "pending:" + todo + "\n"
      formattedTodos += "□ \x1b[37m" + todo + "\x1b[0m\n"
    }

    print(formattedTodos)

    # TODO: maybe this should just go into a file? do we need it at all?
    currentEnv.withStringInput("TODOs", encodedTodos, "Your TODO list")
  }

  """
  Install a tool module into the current environment.
  """
  pub installModule(
    moduleRef: String!,
  ): Env! {
    currentEnv.withModule(moduleSource(moduleRef).asModule)
  }

  """
  Signal that you need a tool that doesn't exist yet. Call this whenever there isn't an obvious existing tool to accomplish the current task. This helps the system learn which capabilities are missing.
  """
  pub wantTool(
    """
    A short, camelCase name for the tool you wish you had (e.g. "runSQL", "deployPreview")
    """
    name: String!,
    """
    A concise description of what the tool would do
    """
    description: String!,
    """
    How you planned to use this tool to accomplish the current task
    """
    plannedUsage: String!,
  ): String! {
    let msg = "🔧 Wanted tool: " + name + "\n"
    msg += "   Description: " + description + "\n"
    msg += "   Planned usage: " + plannedUsage
    print(msg)
    "Noted: tool '" + name + "' is not yet available. Try to accomplish the task using existing tools, or explain to the user what capability is missing."
  }

  let skillsPrompt(workspace: Workspace!): String! {
    let skillDirs = [".doug/skills", ".agents/skills"]
    let skills = [] :: [[String!]!]!

    skillDirs.each { dir =>
      # Discover SKILL.md files recursively
      let skillFiles = try {
        workspace.glob(dir + "/**/SKILL.md")
      } catch {
        _ => [] :: [String!]!
      }

      skillFiles.each { path =>
        let content = try {
          workspace.file(path).contents
        } catch {
          _ => ""
        }
        if (content != "") {
          let fm = content.frontmatter
          if (fm != null) {
            let meta = parseYAML(fm)
            let name = meta.string("name") ?? ""
            let description = meta.string("description") ?? ""
            let disabled = meta.bool("disable-model-invocation") ?? false
            if (description != "" and !disabled) {
              skills = skills + [[name, description, path]]
            }
          }
        }
      }

      # Discover direct .md files at the root of the skills dir
      let rootFiles = try {
        workspace.glob(dir + "/*.md")
      } catch {
        _ => [] :: [String!]!
      }

      rootFiles.each { path =>
        let content = try {
          workspace.file(path).contents
        } catch {
          _ => ""
        }
        if (content != "") {
          let fm = content.frontmatter
          if (fm != null) {
            let meta = parseYAML(fm)
            let name = meta.string("name") ?? ""
            let description = meta.string("description") ?? ""
            let disabled = meta.bool("disable-model-invocation") ?? false
            if (description != "" and !disabled) {
              skills = skills + [[name, description, path]]
            }
          }
        }
      }
    }

    if (skills.length == 0) {
      ""
    } else {
      let prompt = """
      The following skills provide specialized instructions for specific tasks.
      Use the ReadFile tool to load a skill's file when the task matches its description.
      When a skill file references a relative path, resolve it relative to the skill file's directory.

      <available_skills>
      """

      skills.each { skill =>
        prompt = prompt + "  <skill>\n"
        prompt = prompt + "    <name>" + (skill[0] ?? "") + "</name>\n"
        prompt = prompt + "    <description>" + (skill[1] ?? "") + "</description>\n"
        prompt = prompt + "    <location>" + (skill[2] ?? "") + "</location>\n"
        prompt = prompt + "  </skill>\n"
      }

      prompt = prompt + "</available_skills>"
      prompt
    }
  }

  let reminderPrompt(workspace: Workspace!): String! {
    let baseSegment = """
    # System Reminder

    - Do what has been asked; nothing more, nothing less.
    - NEVER create files unless they're absolutely necessary for achieving your goal.
    - ALWAYS prefer editing an existing file to creating a new one.
    - NEVER proactively create documentation files (*.md) or README files.
    - Only create documentation files if explicitly requested by the User.
    """

    let entries = workspace.glob("*.md")
    let contextFiles = ["DOUG.md", "AGENTS.md", "CLAUDE.md"]

    # Look for context files
    let contextSegment = ""
    contextFiles.each { file =>
      if (entries.contains(file)) {
        let fileContents = workspace.file(file).contents
        if (fileContents != "") {
          contextSegment = """
          # Project-Specific Context

          Make sure to follow the instructions in the context below:

          <project-context>
          """ + fileContents + """
          </project-context>

          These instructions OVERRIDE any default behavior.
          """
        }
        break
      }
    }

    baseSegment + contextSegment
  }

  let normalize(path: String!): String! {
    path.trimPrefix(workspacePath)
  }
}
