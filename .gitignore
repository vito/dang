# Grammar wasms: built by build-highlight-assets.sh --grammar-only (which needs
# the tree-sitter CLI), published to R2 by the publishGrammars Dagger function,
# and fetched at build time (--runtime-only). Not committed — the Cloudflare
# build image can't run the CLI to build them.
/docs/js/tree-sitter-dang.wasm
/docs/js/tree-sitter-toml.wasm
/docs/js/tree-sitter-yaml.wasm
/docs/js/tree-sitter-ruby.wasm
/docs/js/tree-sitter-bash.wasm
/docs/js/tree-sitter-go.wasm
.dev.vars
